{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    // Allow declaration emit while TS debt exists (TS6305 without lib/*.d.ts).
    "noEmitOnError": false,
    "baseUrl": "../..",
    "outDir": "lib",
    "rootDir": "src",
    "declarationDir": "lib"
  },
  "include": ["src/**/*", "types/**/*"],
  "exclude": ["src/**/*.test.*", "src/**/*.stories.*"],
  "references": [
    { "path": "../../packages/ax-bi-core" },
    { "path": "../../packages/ax-bi-ui-core" },
    { "path": "../../packages/ax-bi-chart-controls" }
  ]
}
