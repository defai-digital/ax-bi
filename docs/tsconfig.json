{
  // This file is not used in compilation. It is here just for a nice editor experience.
  "extends": "@docusaurus/tsconfig",
  "compilerOptions": {
    "skipLibCheck": true,
    "noImplicitAny": false,
    "strict": false,
    "jsx": "react-jsx",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "types": ["@docusaurus/module-type-aliases"],
    "paths": {
      "@ax-bi/ui-core": ["../ax-bi-frontend/packages/ax-bi-ui-core/src"],
      "@ax-bi/ui-core/*": ["../ax-bi-frontend/packages/ax-bi-ui-core/src/*"],
      // Types for @ax-bi/core/components are auto-generated by scripts/generate-axbi-components.mjs
      // Runtime resolution uses webpack alias pointing to actual source (see src/webpack.extend.ts)
      "@ax-bi/core/components": ["./src/types/ax-bi-core"],
      "*": ["src/*", "node_modules/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "../ax-bi-frontend/**/*",
    "src/webpack.extend.ts",
    "src/shims/**"
  ]
}
