{
  "name": "ax-bi-desktop",
  "version": "2.2.1",
  "type": "module",
  "description": "AX BI Desktop Client - A thin shell for the AX BI analytics platform",
  "private": true,
  "scripts": {
    "tauri": "npx tauri",
    "type": "tsc --noEmit",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "dev": "npx tauri dev",
    "build": "npx tauri build",
    "build:debug": "npx tauri build --debug",
    "release:set-version": "node scripts/release/set-version.mjs",
    "release:write-cask": "node scripts/release/write-homebrew-cask.mjs",
    "release:write-winget": "node scripts/release/write-winget-manifests.mjs",
    "release:minisign": "node scripts/release/minisign-artifacts.mjs",
    "test:release-signing": "node --test scripts/release/release-signing.test.mjs scripts/release/write-winget-manifests.test.mjs",
    "test:winget-manifests": "node --test scripts/release/write-winget-manifests.test.mjs",
    "release:notarize": "bash scripts/release/notarize-macos.sh"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "@tauri-apps/plugin-notification": "^2.0.0",
    "@tauri-apps/plugin-deep-link": "^2.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
