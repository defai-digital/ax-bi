{
  "productName": "AX BI",
  "version": "0.1.0",
  "identifier": "com.axbi.desktop",
  "build": {
    "frontendDist": "../src",
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AX BI",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": "default-src 'self' data: blob: http://127.0.0.1:* ws://127.0.0.1:*; script-src 'self'; style-src 'self'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:* https:; frame-src 'self' data: blob: http://127.0.0.1:* http://localhost:* https:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["axbi"]
      }
    }
  }
}
