{
  "productName": "AX BI",
  "version": "2.0.3",
  "identifier": "com.axbi.desktop",
  "build": {
    "frontendDist": "../src",
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AX BI",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": "default-src 'self' data: blob: http://127.0.0.1:* ws://127.0.0.1:*; script-src 'self'; style-src 'self'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:* https:; frame-src 'self' data: blob: http://127.0.0.1:* http://localhost:* https:"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "targets": [
      "app",
      "dmg",
      "nsis",
      "msi"
    ],
    "publisher": "DEFAI Private Limited",
    "shortDescription": "AX BI desktop client",
    "longDescription": "Desktop client and local runtime launcher for the AX BI analytics platform.",
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "axbi"
        ]
      }
    }
  }
}
