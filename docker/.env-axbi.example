# Copy this file to docker/.env-axbi and fill in the required values before
# running docker-compose-axbi.yml.
#
# Generate secrets:
#   openssl rand -base64 42

COMPOSE_PROJECT_NAME=axbi

# Required secrets
SUPERSET_SECRET_KEY=
DATABASE_PASSWORD=
ADMIN_PASSWORD=

# Image settings. Override these to use a newer release tag or private images.
AXBI_IMAGE=ghcr.io/defai-digital/ax-bi:v1.0.2
AX_SERVICES_IMAGE=ghcr.io/defai-digital/ax-bi-services:v1.0.2

# Service ports
SUPERSET_PORT=8088
MCP_PORT=5008
AX_SERVICES_PORT=5010

# Metadata database
POSTGRES_IMAGE=pgvector/pgvector:pg18
DATABASE_DB=superset
DATABASE_USER=superset
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_DIALECT=postgresql
POSTGRES_DB=superset
POSTGRES_USER=superset

# Runtime behavior
SUPERSET_LOAD_EXAMPLES=no
SUPERSET_LOG_LEVEL=info
ENABLE_PROXY_FIX=true

# GenAI semantic index.
# Start the host-side embedding proxy before enabling:
#   python scripts/semantic_index/prepare_qwen3_embedding_mlx.py
#   python scripts/semantic_index/ax_engine_embedding_server.py \
#     --model-dir models/qwen3-embedding-0.6b-mlx
GENAI_SEMANTIC_INDEX=false
GENAI_SEMANTIC_INDEX_PGVECTOR=false
AI_SEMANTIC_EMBEDDING_PROVIDER=ax_engine_http
AI_SEMANTIC_EMBEDDING_ENDPOINT=http://host.docker.internal:8099/embed
AI_SEMANTIC_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
AI_SEMANTIC_EMBEDDING_DIMENSIONS=1024
AI_SEMANTIC_EMBEDDING_TIMEOUT=120

# MCP authentication.
# For a local single-user trial, set MCP_DEV_USERNAME=admin.
# For production, leave MCP_DEV_USERNAME empty and configure JWT settings.
MCP_DEV_USERNAME=
MCP_AUTH_ENABLED=false
MCP_JWT_ISSUER=
MCP_JWT_AUDIENCE=
MCP_JWKS_URI=
MCP_REQUIRED_SCOPES=
