# Copy this file to docker/.env-axbi and fill in the required values before
# running docker-compose-axbi.yml.
#
# Generate secrets:
#   openssl rand -base64 42

COMPOSE_PROJECT_NAME=axbi

# Required secrets
AX_BI_SECRET_KEY=
DATABASE_PASSWORD=
ADMIN_PASSWORD=

# Image settings. Override these to use a pinned release tag or private images.
AXBI_IMAGE=ghcr.io/defai-digital/ax-bi:latest
AX_SERVICES_IMAGE=ghcr.io/defai-digital/ax-bi-services:latest

# Service ports
AXBI_PORT=31423
MCP_PORT=31421
AX_SERVICES_PORT=31424

# Metadata database
POSTGRES_IMAGE=pgvector/pgvector:pg18
DATABASE_DB=axbi
DATABASE_USER=axbi
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_DIALECT=postgresql
POSTGRES_DB=axbi
POSTGRES_USER=axbi

# Local upload storage. These paths are inside the shared axbi_home volume.
UPLOAD_FOLDER=/app/axbi_home/uploads
LOCAL_DB_NAME=Local Files
LOCAL_DB_PATH=/app/axbi_home/uploads/local_files.duckdb

# Runtime behavior
AXBI_LOAD_EXAMPLES=no
AXBI_LOG_LEVEL=info
ENABLE_PROXY_FIX=true

# ---------------------------------------------------------------------------
# GenAI BI / prompt-to-dashboard (required for Codex, Claude Code, etc.)
# ---------------------------------------------------------------------------
# These flags must be true for high-level AI MCP tools to appear:
#   prompt_to_dashboard, plan_dashboard, create_chart_from_intent, ...
# GENAI_BI alone is NOT enough.
GENAI_BI=true
GENAI_BI_MCP_TOOLS=true
GENAI_PROMPT_TO_DASHBOARD=true
GENAI_EMBEDDED_ASSISTANT=false

# Optional server-side LLM for better intent mapping (recommended for production).
# When unset, tools use keyword heuristics only.
# GENAI_LLM_PROVIDER=anthropic
# GENAI_LLM_API_KEY=
# GENAI_LLM_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_API_KEY=   # alternative to GENAI_LLM_API_KEY for anthropic

# GenAI semantic index (optional; improves asset discovery beyond keyword match).
# Lexical/token search works without this. Enable both flags when embeddings +
# pgvector are available for true semantic retrieval.
# Start the host-side embedding proxy before enabling:
#   python scripts/semantic_index/prepare_qwen3_embedding_mlx.py
#   python scripts/semantic_index/ax_engine_embedding_server.py \
#     --model-dir models/qwen3-embedding-0.6b-mlx
GENAI_SEMANTIC_INDEX=false
GENAI_SEMANTIC_INDEX_PGVECTOR=false
AI_SEMANTIC_EMBEDDING_PROVIDER=ax_engine_http
AI_SEMANTIC_EMBEDDING_ENDPOINT=http://host.docker.internal:8099/embed
AI_SEMANTIC_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
AI_SEMANTIC_EMBEDDING_DIMENSIONS=1024
AI_SEMANTIC_EMBEDDING_TIMEOUT=120

# MCP authentication.
# For a local single-user trial, set MCP_DEV_USERNAME=admin.
# For production, leave MCP_DEV_USERNAME empty and configure JWT settings.
MCP_DEV_USERNAME=
MCP_AUTH_ENABLED=false
MCP_JWT_ISSUER=
MCP_JWT_AUDIENCE=
MCP_JWKS_URI=
MCP_REQUIRED_SCOPES=
