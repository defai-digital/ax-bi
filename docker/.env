# Allowing python to print() in docker
PYTHONUNBUFFERED=1

COMPOSE_PROJECT_NAME=axbi
DEV_MODE=true

# Port configuration (override in .env-local for multiple instances)
# NGINX_PORT=80
# AXBI_PORT=8088
# NODE_PORT=9000
# WEBSOCKET_PORT=8080
# CYPRESS_PORT=8081
# DATABASE_PORT=5432
# REDIS_PORT=6379

# database configurations (do not modify)
DATABASE_DB=axbi
DATABASE_HOST=db
# Make sure you set this to a unique secure random value on production
DATABASE_PASSWORD=axbi
DATABASE_USER=axbi

EXAMPLES_DB=examples
EXAMPLES_HOST=db
EXAMPLES_USER=examples
# Make sure you set this to a unique secure random value on production
EXAMPLES_PASSWORD=examples
EXAMPLES_PORT=5432

# database engine specific environment variables
# change the below if you prefer another database engine
DATABASE_PORT=5432
DATABASE_DIALECT=postgresql
POSTGRES_DB=axbi
POSTGRES_USER=axbi
# Make sure you set this to a unique secure random value on production
POSTGRES_PASSWORD=axbi
#MYSQL_DATABASE=axbi
#MYSQL_USER=axbi
#MYSQL_PASSWORD=axbi
#MYSQL_RANDOM_ROOT_PASSWORD=yes

# Add the mapped in /app/pythonpath_docker which allows devs to override stuff
PYTHONPATH=/app/pythonpath:/app/docker/pythonpath_dev
REDIS_HOST=redis
REDIS_PORT=6379

# Development and logging configuration
# FLASK_DEBUG: Enables Flask dev features (auto-reload, better error pages) - keep 'true' for development
FLASK_DEBUG=true
# AXBI_LOG_LEVEL: Controls AxBI application logging verbosity (debug, info, warning, error, critical)
AXBI_LOG_LEVEL=info

AXBI_APP_ROOT="/"
AXBI_ENV=development
AXBI_LOAD_EXAMPLES=yes
CYPRESS_CONFIG=false
AXBI_PORT=8088
MAPBOX_API_KEY=''

# Make sure you set this to a unique secure random value on production
AXBI_SECRET_KEY=TEST_NON_DEV_SECRET
ENABLE_PLAYWRIGHT=false
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
BUILD_AXBI_FRONTEND_IN_DOCKER=true
