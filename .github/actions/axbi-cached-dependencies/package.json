{
  "name": "setup-ax-bi-action",
  "version": "1.0.0",
  "private": true,
  "keywords": [
    "actions",
    "node",
    "setup",
    "ax-bi"
  ],
  "main": "dist/run",
  "scripts": {
    "all": "npm run format && npm run lint && npm run test && npm run build",
    "build": "npm run clean && tsc && ncc build -o dist src/run.ts && ncc build -o dist/scripts/cache src/scripts/cache.ts && node scripts/normalize-dist.mjs",
    "clean": "rm -rf ./lib ./dist",
    "coverage": "npm run test && open ./coverage/lcov-report/index.html",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint src/**/*.ts",
    "test": "jest --clearCache && jest --coverage"
  },
  "dependencies": {
    "@actions/cache": "5.1.0",
    "@actions/core": "2.0.3",
    "@actions/exec": "2.0.0",
    "@actions/glob": "0.5.1",
    "hasha": "5.2.0"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/node": "20.19.27",
    "@typescript-eslint/eslint-plugin": "8.63.0",
    "@typescript-eslint/parser": "8.63.0",
    "@vercel/ncc": "0.44.1",
    "eslint": "8.57.1",
    "jest": "29.7.0",
    "prettier": "2.0.5",
    "prettier-plugin-packagejson": "2.2.5",
    "ts-jest": "29.4.11",
    "typescript": "5.9.3"
  }
}
