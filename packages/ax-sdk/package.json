{
  "name": "@defai/ax-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for integrating with AX BI analytics platform",
  "author": "DEFAI Private Limited",
  "keywords": [
    "ax-bi",
    "axbi",
    "analytics",
    "bi",
    "sdk",
    "mcp",
    "dashboard",
    "genai"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/defai-digital/ax-bi.git",
    "directory": "packages/ax-sdk"
  },
  "homepage": "https://github.com/defai-digital/ax-bi/tree/main/packages/ax-sdk#readme",
  "bugs": {
    "url": "https://github.com/defai-digital/ax-bi/issues"
  },
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && npm run build:types",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:types": "tsc -p tsconfig.types.json",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "type": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  }
}
